
# ignore everything in the root except the "wp-content" directory.
/*
!wp-content/
!.editorconfig
!.gitignore
!.htaccess.local
!.lando.yml
!readme.md
!wp-config-lando.php
!apple-touch-icon.png
!favicon.ico
!favicon.svg
!favicon-96x96.png
!site.webmanifest
!web-app-manifest-192x192.png
!web-app-manifest-512x512.png

# ignore OS generated files
ehthumbs.db
Thumbs.db
.DS_Store

# ignore log files and databases
*.log
*.sql
*.sqlite

# ignore everything in the "wp-content" directory, except:
# "mu-plugins" directory
# "plugins" directory
# "themes" directory
!wp-content/plugins/**/.*

# ignore specific themes
wp-content/uploads
wp-content/upgrade
wp-content/upgrade-temp-backup
wp-content/aiowps_backups

wp-content/themes/*/.config.json
wp-content/themes/*/admin/css-dev/
wp-content/themes/*/assets/css-dev/
wp-content/themes/*/assets/js-dev/

# ignore node/grunt dependency directories
node_modules/
.sass-cache/
yarn.lock
